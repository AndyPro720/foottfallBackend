rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Get user data
    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if user is admin
    function isAdmin() {
      let role = getUser().role;
      return role == 'admin' || role == 'superadmin';
    }

    // Helper: Check if user is superadmin
    function isSuperAdmin() {
      return getUser().role == 'superadmin';
    }

    // Helper: Check if user is active
    function isActive() {
      return getUser().status == 'active';
    }

    // Rules for Users collection
    match /users/{userId} {
      // Owners can read their own profile. Admins can read all.
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Update logic protects superadmin status and privileges
      allow update: if request.auth != null && (
        isSuperAdmin() || 
        (
          isAdmin() && !isSuperAdmin() &&
          // Admin cannot modify a superadmin
          resource.data.role != 'superadmin' &&
          // Admin cannot promote someone to superadmin
          request.resource.data.role != 'superadmin'
        ) ||
        (
          request.auth.uid == userId && 
          // Users can update their own profile EXCEPT role and status
          request.resource.data.role == resource.data.role && 
          request.resource.data.status == resource.data.status
        )
      );
      
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && isSuperAdmin();
    }

    // Rules for Invites collection
    match /invites/{emailId} {
      // Only superadmin can create or delete invites
      allow write: if request.auth != null && isSuperAdmin();
      // Allow read to superadmin AND the user themselves
      allow read: if request.auth != null;
    }

    // Rules for Inventory collection
    match /inventory/{itemId} {
      allow create: if request.auth != null && isActive();
      
      allow read: if request.auth != null && (
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
      
      allow update, delete: if request.auth != null && isActive() && (
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
