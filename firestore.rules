rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: Firebase Auth UID
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID.
    //   - email: string (required, immutable for non-admin self updates).
    //   - displayName: string (optional).
    //   - role: "agent" | "admin" | "superadmin" (required).
    //   - status: "pending" | "active" | "suspended" (required).
    //   - createdAt: timestamp (required, immutable).
    //   - lastLogin: timestamp (optional).
    //   - updatedAt: timestamp (optional).
    //
    // Collection: invites
    // Document ID: lowercase invited email address
    // Fields:
    //   - email: string (required, must equal document ID).
    //   - createdAt: timestamp (required).
    //   - createdBy: string (required, creator UID).
    //
    // Collection: inventory
    // Document ID: auto-generated
    // Fields:
    //   - property form fields: optional strings, numbers, booleans, URL lists/maps.
    //   - createdBy: string (required, immutable) - creator UID.
    //   - creatorEmail/creatorName: string (required, immutable).
    //   - created_at: timestamp (required, immutable).
    //   - updated_at: timestamp (required).
    //   - status: "active" | "pending" | "inactive" (required).
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function invitePath(email) {
      return /databases/$(database)/documents/invites/$(email);
    }

    function getUser() {
      return get(userPath(request.auth.uid)).data;
    }

    function signedInEmail() {
      return request.auth.token.email.lower();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function roleIs(role) {
      return isAuthenticated() &&
        exists(userPath(request.auth.uid)) &&
        getUser().status == 'active' &&
        getUser().role == role;
    }

    function isAdmin() {
      return roleIs('admin') || roleIs('superadmin');
    }

    function isSuperAdmin() {
      return roleIs('superadmin');
    }

    function isActive() {
      return isAuthenticated() &&
        exists(userPath(request.auth.uid)) &&
        getUser().status == 'active';
    }

    function validString(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function validOptionalTimestamp(data, field) {
      return !(field in data) || data[field] is timestamp;
    }

    // ===============================================================
    // Inventory Validation (Lightweight)
    // ===============================================================
    //
    // Detailed per-field type/range/format validation is handled
    // client-side by src/backend/inventoryValidator.js. The client
    // validator mirrors every rule and shows the exact failing field
    // to the user.
    //
    // Server-side rules focus on:
    //  1. Allowed key guard (no unexpected top-level fields)
    //  2. Required key presence
    //  3. Creator/ownership integrity
    //  4. Status enum
    //
    // This keeps expression count well under Firestore's ~1000 limit
    // even when all 50+ optional fields are populated.
    // ===============================================================

    function isProjectCreator(projectId) {
      let path = /databases/$(database)/documents/projects/$(projectId);
      return exists(path) && get(path).data.createdBy == request.auth.uid;
    }

    function inventoryAllowedKeys() {
      return [
        'name',
        'unitName',
        'projectId',
        'frontage',
        'vicinityBrands',
        'miscNotes',
        'propertyStatus',
        'completionTime',
        'partOC',
        'completeOC',
        'buildingType',
        'size',
        'floor',
        'googleMapsLink',
        'location',
        'city',
        'tradeArea',
        'suitableFor',
        'presentationAvailable',
        'presentationLink',
        'presentationFile',
        'contactName',
        'contactDesignation',
        'contactInfo',
        'price',
        'priceNegotiability',
        'mergable',
        'mezzanine',
        'mezzanineSize',
        'clearHeight',
        'clearHeightUnderMezz',
        'clearHeightAboveMezz',
        'cam',
        'connectedLoad',
        'buildingAge',
        'parking',
        'parkingCount',
        'parkingPhoto',
        'outsideSpace',
        'outsideSpacePhoto',
        'serviceEntry',
        'serviceEntryPhoto',
        'liftAccess',
        'liftAccessPhoto',
        'bohSpace',
        'bohSpacePhoto',
        'fireExit',
        'ocFile',
        'latitude',
        'longitude',
        'status',
        'images',
        'mediaUploadPending',
        'syncPending',
        'createdBy',
        'creatorEmail',
        'creatorName',
        'created_at',
        'updated_at'
      ];
    }

    function isValidInventory(data) {
      return data.keys().hasOnly(inventoryAllowedKeys()) &&
        data.keys().hasAll(['name', 'status', 'createdBy', 'created_at', 'updated_at']) &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() <= 200 &&
        data.createdBy is string &&
        data.creatorEmail is string &&
        data.creatorName is string &&
        (
          data.status == 'active' ||
          data.status == 'pending' ||
          data.status == 'inactive'
        ) &&
        (!('images' in data) || data.images is map);
    }

    // ===============================================================
    // User / Invite Validation
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'displayName', 'role', 'status', 'createdAt', 'lastLogin', 'updatedAt']) &&
        data.keys().hasAll(['uid', 'email', 'role', 'status', 'createdAt']) &&
        data.uid is string &&
        data.uid.size() <= 128 &&
        data.email is string &&
        data.email.size() <= 320 &&
        (!('displayName' in data) || validString(data.displayName, 200)) &&
        (
          data.role == 'agent' ||
          data.role == 'admin' ||
          data.role == 'superadmin'
        ) &&
        (
          data.status == 'pending' ||
          data.status == 'active' ||
          data.status == 'suspended'
        ) &&
        data.createdAt is timestamp &&
        validOptionalTimestamp(data, 'lastLogin') &&
        validOptionalTimestamp(data, 'updatedAt');
    }

    function isValidInvite(data, emailId) {
      return data.keys().hasOnly(['email', 'createdAt', 'createdBy']) &&
        data.keys().hasAll(['email', 'createdAt', 'createdBy']) &&
        data.email == emailId &&
        data.email is string &&
        data.email.size() <= 320 &&
        data.createdAt is timestamp &&
        data.createdBy == request.auth.uid;
    }

    function inventoryImmutableFieldsUnchanged() {
      return request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.creatorEmail == resource.data.creatorEmail &&
        request.resource.data.creatorName == resource.data.creatorName &&
        request.resource.data.created_at == resource.data.created_at;
    }

    // ===============================================================
    // Project Validation
    // ===============================================================

    function projectsAllowedKeys() {
      return [
        'name',
        'vicinityBrands',
        'buildingType',
        'googleMapsLink',
        'location',
        'city',
        'tradeArea',
        'buildingAge',
        'contactName',
        'contactDesignation',
        'contactInfo',
        'latitude',
        'longitude',
        'unitCount',
        'images',
        'status',
        'mediaUploadPending',
        'syncPending',
        'createdBy',
        'creatorEmail',
        'creatorName',
        'created_at',
        'updated_at'
      ];
    }

    function isValidProject(data) {
      return data.keys().hasOnly(projectsAllowedKeys()) &&
        data.keys().hasAll(['name', 'createdBy', 'created_at', 'updated_at']) &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() <= 200 &&
        data.createdBy is string &&
        (!('creatorEmail' in data) || data.creatorEmail is string) &&
        (!('creatorName' in data) || data.creatorName is string);
    }

    function projectImmutableFieldsUnchanged() {
      return request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.creatorEmail == resource.data.creatorEmail &&
        request.resource.data.creatorName == resource.data.creatorName &&
        request.resource.data.created_at == resource.data.created_at;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        resource.data.createdBy == request.auth.uid ||
        !('createdBy' in resource.data)
      );

      allow create: if isActive() &&
        isValidProject(request.resource.data) &&
        request.resource.data.createdBy == request.auth.uid;

      allow update: if isActive() &&
        isValidProject(request.resource.data) &&
        projectImmutableFieldsUnchanged() &&
        (isAdmin() || resource.data.createdBy == request.auth.uid);

      allow delete: if isActive() &&
        (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) ||
        isAdmin() ||
        (isAuthenticated() && request.auth.token.email == 'trancidence@gmail.com');

      allow create: if isOwner(userId) &&
        isValidUser(request.resource.data) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        (
          (
            request.resource.data.role == 'agent' &&
            (
              request.resource.data.status == 'pending' ||
              (
                request.resource.data.status == 'active' &&
                exists(invitePath(signedInEmail()))
              )
            )
          ) ||
          (
            request.resource.data.role == 'superadmin' &&
            request.resource.data.status == 'active' &&
            request.auth.token.email == 'trancidence@gmail.com'
          )
        );

      allow update: if isAuthenticated() &&
        isValidUser(request.resource.data) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        (
          isSuperAdmin() ||
          (
            isAdmin() &&
            resource.data.role != 'superadmin' &&
            request.resource.data.role != 'superadmin'
          ) ||
          (
            isOwner(userId) &&
            request.resource.data.role == resource.data.role &&
            request.resource.data.status == resource.data.status &&
            request.resource.data.email == resource.data.email
          )
        );

      allow delete: if isSuperAdmin() && resource.data.role != 'superadmin';
    }

    match /invites/{emailId} {
      allow read: if isSuperAdmin() ||
        (isAuthenticated() && emailId == signedInEmail());

      allow create, update: if isSuperAdmin() &&
        isValidInvite(request.resource.data, emailId);

      allow delete: if isSuperAdmin() ||
        (
          isAuthenticated() &&
          emailId == signedInEmail() &&
          exists(userPath(request.auth.uid)) &&
          get(userPath(request.auth.uid)).data.status == 'active'
        );
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        resource.data.createdBy == request.auth.uid ||
        !('createdBy' in resource.data) ||
        ('projectId' in resource.data && resource.data.projectId != null && isProjectCreator(resource.data.projectId))
      );

      allow create: if isActive() &&
        isValidInventory(request.resource.data) &&
        request.resource.data.createdBy == request.auth.uid;

      allow update: if isActive() &&
        isValidInventory(request.resource.data) &&
        inventoryImmutableFieldsUnchanged() &&
        (isAdmin() || resource.data.createdBy == request.auth.uid);

      allow delete: if isActive() &&
        (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
