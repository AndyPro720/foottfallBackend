rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Get user data
    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if user is admin
    function isAdmin() {
      return getUser().role == 'admin';
    }

    // Helper: Check if user is active
    function isActive() {
      return getUser().status == 'active';
    }

    // Rules for Users collection
    match /users/{userId} {
      // Owners can read/write their own profile
      // Admins can manage all user profiles (needed for approval)
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && isAdmin();
    }

    // Rules for Inventory collection
    match /inventory/{itemId} {
      // Create: user must be authenticated and ACTIVE
      allow create: if request.auth != null && isActive();
      
      // Read: owner or admin
      allow read: if request.auth != null && (
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
      
      // Update/Delete: owner or admin (AND ACTIVE)
      allow update, delete: if request.auth != null && isActive() && (
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
