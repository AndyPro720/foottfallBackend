rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: Firebase Auth UID
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID.
    //   - email: string (required, immutable for non-admin self updates).
    //   - displayName: string (optional).
    //   - role: "agent" | "admin" | "superadmin" (required).
    //   - status: "pending" | "active" | "suspended" (required).
    //   - createdAt: timestamp (required, immutable).
    //   - lastLogin: timestamp (optional).
    //   - updatedAt: timestamp (optional).
    //
    // Collection: invites
    // Document ID: lowercase invited email address
    // Fields:
    //   - email: string (required, must equal document ID).
    //   - createdAt: timestamp (required).
    //   - createdBy: string (required, creator UID).
    //
    // Collection: inventory
    // Document ID: auto-generated
    // Fields:
    //   - property form fields: optional strings, numbers, booleans, URL lists/maps.
    //   - createdBy: string (required, immutable) - creator UID.
    //   - creatorEmail/creatorName: string (required, immutable).
    //   - created_at: timestamp (required, immutable).
    //   - updated_at: timestamp (required).
    //   - status: "active" | "pending" | "inactive" (required).
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function invitePath(email) {
      return /databases/$(database)/documents/invites/$(email);
    }

    function getUser() {
      return get(userPath(request.auth.uid)).data;
    }

    function signedInEmail() {
      return request.auth.token.email.lower();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function roleIs(role) {
      return isAuthenticated() &&
        exists(userPath(request.auth.uid)) &&
        getUser().status == 'active' &&
        getUser().role == role;
    }

    function isAdmin() {
      return roleIs('admin') || roleIs('superadmin');
    }

    function isSuperAdmin() {
      return roleIs('superadmin');
    }

    function isActive() {
      return isAuthenticated() &&
        exists(userPath(request.auth.uid)) &&
        getUser().status == 'active';
    }

    function validString(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function validOptionalString(data, field, maxLen) {
      return !(field in data) || validString(data[field], maxLen) || data[field] == null;
    }

    function validOptionalNumber(data, field, min, max) {
      return !(field in data) || (data[field] is number && data[field] >= min && data[field] <= max);
    }

    function validOptionalBool(data, field) {
      return !(field in data) || data[field] is bool;
    }

    function validOptionalBoolLike(data, field) {
      return !(field in data) ||
        data[field] is bool ||
        data[field] == null ||
        validString(data[field], 50);
    }

    function validOptionalTimestamp(data, field) {
      return !(field in data) || data[field] is timestamp;
    }

    function validOptionalUrl(data, field) {
      return !(field in data) ||
        data[field] == null ||
        (data[field] is string &&
          data[field].size() <= 2048 &&
          (data[field].matches('https://.*') || data[field].matches('http://.*')));
    }

    function validOptionalUrlOrList(data, field) {
      return !(field in data) ||
        data[field] == null ||
        (data[field] is list && data[field].size() <= 50) ||
        (data[field] is string &&
          data[field].size() <= 2048 &&
          (data[field].matches('https://.*') || data[field].matches('http://.*') || data[field].size() <= 200));
    }

    function validOptionalUrlList(data, field) {
      return !(field in data) ||
        (data[field] is list && data[field].size() <= 50);
    }

    function validImages(data) {
      return !('images' in data) ||
        (data.images is map &&
          data.images.keys().hasOnly([
            'entryToBuilding',
            'buildingFacade',
            'unitFacade',
            'interior',
            'signage',
            'floorPlan',
            'presentationFile',
            'ocFile'
          ]) &&
          validOptionalUrlList(data.images, 'entryToBuilding') &&
          validOptionalUrlList(data.images, 'buildingFacade') &&
          validOptionalUrlList(data.images, 'unitFacade') &&
          validOptionalUrlList(data.images, 'interior') &&
          validOptionalUrlList(data.images, 'signage') &&
          validOptionalUrlList(data.images, 'floorPlan') &&
          validOptionalUrlList(data.images, 'presentationFile') &&
          validOptionalUrlList(data.images, 'ocFile'));
    }

    function inventoryAllowedKeys() {
      return [
        'name',
        'frontage',
        'vicinityBrands',
        'miscNotes',
        'propertyStatus',
        'completionTime',
        'partOC',
        'completeOC',
        'buildingType',
        'size',
        'floor',
        'googleMapsLink',
        'location',
        'city',
        'tradeArea',
        'suitableFor',
        'presentationAvailable',
        'presentationLink',
        'presentationFile',
        'contactName',
        'contactDesignation',
        'contactInfo',
        'price',
        'priceNegotiability',
        'mergable',
        'mezzanine',
        'mezzanineSize',
        'clearHeight',
        'clearHeightUnderMezz',
        'clearHeightAboveMezz',
        'cam',
        'connectedLoad',
        'buildingAge',
        'parking',
        'parkingCount',
        'parkingPhoto',
        'outsideSpace',
        'outsideSpacePhoto',
        'serviceEntry',
        'serviceEntryPhoto',
        'liftAccess',
        'liftAccessPhoto',
        'bohSpace',
        'bohSpacePhoto',
        'fireExit',
        'ocFile',
        'latitude',
        'longitude',
        'status',
        'images',
        'mediaUploadPending',
        'syncPending',
        'createdBy',
        'creatorEmail',
        'creatorName',
        'created_at',
        'updated_at'
      ];
    }

    function validInventoryStrings(data) {
      return validOptionalString(data, 'name', 200) &&
        validOptionalString(data, 'frontage', 100) &&
        validOptionalString(data, 'vicinityBrands', 1000) &&
        validOptionalString(data, 'miscNotes', 5000) &&
        validOptionalString(data, 'partOC', 200) &&
        validOptionalString(data, 'completeOC', 200) &&
        validOptionalString(data, 'floor', 100) &&
        validOptionalString(data, 'propertyStatus', 100) &&
        validOptionalString(data, 'buildingType', 100) &&
        validOptionalString(data, 'priceNegotiability', 100) &&
        validOptionalString(data, 'location', 2000) &&
        validOptionalString(data, 'city', 120) &&
        validOptionalString(data, 'tradeArea', 200) &&
        validOptionalString(data, 'suitableFor', 1000) &&
        validOptionalString(data, 'contactName', 200) &&
        validOptionalString(data, 'contactDesignation', 200) &&
        validOptionalString(data, 'contactInfo', 500) &&
        validOptionalString(data, 'creatorEmail', 320) &&
        validOptionalString(data, 'creatorName', 200);
    }

    function validInventoryEnums(data) {
      return !('status' in data) || data.status in ['active', 'pending', 'inactive'];
    }

    function validInventoryNumbers(data) {
      return validOptionalNumber(data, 'completionTime', 0, 600) &&
        validOptionalNumber(data, 'size', 0, 100000000) &&
        validOptionalNumber(data, 'price', 0, 1000000000) &&
        validOptionalNumber(data, 'mezzanineSize', 0, 100000000) &&
        validOptionalNumber(data, 'clearHeight', 0, 10000) &&
        validOptionalNumber(data, 'clearHeightUnderMezz', 0, 10000) &&
        validOptionalNumber(data, 'clearHeightAboveMezz', 0, 10000) &&
        validOptionalNumber(data, 'cam', 0, 1000000000) &&
        validOptionalNumber(data, 'connectedLoad', 0, 10000000) &&
        validOptionalNumber(data, 'buildingAge', 0, 1000) &&
        validOptionalNumber(data, 'parkingCount', 0, 100000) &&
        validOptionalNumber(data, 'latitude', -90, 90) &&
        validOptionalNumber(data, 'longitude', -180, 180);
    }

    function validInventoryBools(data) {
      return validOptionalBoolLike(data, 'presentationAvailable') &&
        validOptionalBoolLike(data, 'mergable') &&
        validOptionalBoolLike(data, 'mezzanine') &&
        validOptionalBoolLike(data, 'parking') &&
        validOptionalBoolLike(data, 'outsideSpace') &&
        validOptionalBoolLike(data, 'serviceEntry') &&
        validOptionalBoolLike(data, 'liftAccess') &&
        validOptionalBoolLike(data, 'bohSpace') &&
        validOptionalBoolLike(data, 'fireExit') &&
        validOptionalBool(data, 'mediaUploadPending') &&
        validOptionalBool(data, 'syncPending');
    }

    function validInventoryUrls(data) {
      return validOptionalUrl(data, 'googleMapsLink') &&
        validOptionalUrl(data, 'presentationLink') &&
        validOptionalUrlOrList(data, 'presentationFile') &&
        validOptionalUrl(data, 'parkingPhoto') &&
        validOptionalUrl(data, 'outsideSpacePhoto') &&
        validOptionalUrl(data, 'serviceEntryPhoto') &&
        validOptionalUrl(data, 'liftAccessPhoto') &&
        validOptionalUrl(data, 'bohSpacePhoto') &&
        validOptionalUrlOrList(data, 'ocFile');
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'displayName', 'role', 'status', 'createdAt', 'lastLogin', 'updatedAt']) &&
        data.keys().hasAll(['uid', 'email', 'role', 'status', 'createdAt']) &&
        data.uid is string &&
        data.uid.size() <= 128 &&
        data.email is string &&
        data.email.size() <= 320 &&
        (!('displayName' in data) || validString(data.displayName, 200)) &&
        data.role in ['agent', 'admin', 'superadmin'] &&
        data.status in ['pending', 'active', 'suspended'] &&
        data.createdAt is timestamp &&
        validOptionalTimestamp(data, 'lastLogin') &&
        validOptionalTimestamp(data, 'updatedAt');
    }

    function isValidInvite(data, emailId) {
      return data.keys().hasOnly(['email', 'createdAt', 'createdBy']) &&
        data.keys().hasAll(['email', 'createdAt', 'createdBy']) &&
        data.email == emailId &&
        data.email is string &&
        data.email.size() <= 320 &&
        data.createdAt is timestamp &&
        data.createdBy == request.auth.uid;
    }

    function isValidInventory(data) {
      return data.keys().hasOnly(inventoryAllowedKeys()) &&
        data.keys().hasAll(['name', 'status', 'createdBy', 'creatorEmail', 'creatorName', 'created_at', 'updated_at']) &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() <= 200 &&
        data.createdBy is string &&
        data.createdBy.size() <= 128 &&
        data.created_at is timestamp &&
        data.updated_at is timestamp &&
        validInventoryStrings(data) &&
        validInventoryEnums(data) &&
        validInventoryNumbers(data) &&
        validInventoryBools(data) &&
        validInventoryUrls(data) &&
        validImages(data);
    }

    function inventoryImmutableFieldsUnchanged() {
      return request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.creatorEmail == resource.data.creatorEmail &&
        request.resource.data.creatorName == resource.data.creatorName &&
        request.resource.data.created_at == resource.data.created_at;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) ||
        isAdmin() ||
        (isAuthenticated() && request.auth.token.email == 'trancidence@gmail.com');

      allow create: if isOwner(userId) &&
        isValidUser(request.resource.data) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        (
          (
            request.resource.data.role == 'agent' &&
            (
              request.resource.data.status == 'pending' ||
              (
                request.resource.data.status == 'active' &&
                exists(invitePath(signedInEmail()))
              )
            )
          ) ||
          (
            request.resource.data.role == 'superadmin' &&
            request.resource.data.status == 'active' &&
            request.auth.token.email == 'trancidence@gmail.com'
          )
        );

      allow update: if isAuthenticated() &&
        isValidUser(request.resource.data) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        (
          isSuperAdmin() ||
          (
            isAdmin() &&
            resource.data.role != 'superadmin' &&
            request.resource.data.role != 'superadmin'
          ) ||
          (
            isOwner(userId) &&
            request.resource.data.role == resource.data.role &&
            request.resource.data.status == resource.data.status &&
            request.resource.data.email == resource.data.email
          )
        );

      allow delete: if isSuperAdmin() && resource.data.role != 'superadmin';
    }

    match /invites/{emailId} {
      allow read: if isSuperAdmin() ||
        (isAuthenticated() && emailId == signedInEmail());

      allow create, update: if isSuperAdmin() &&
        isValidInvite(request.resource.data, emailId);

      allow delete: if isSuperAdmin() ||
        (
          isAuthenticated() &&
          emailId == signedInEmail() &&
          exists(userPath(request.auth.uid)) &&
          get(userPath(request.auth.uid)).data.status == 'active'
        );
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated() &&
        (isAdmin() || resource.data.createdBy == request.auth.uid);

      allow create: if isActive() &&
        isValidInventory(request.resource.data) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.creatorEmail == request.auth.token.email;

      allow update: if isActive() &&
        isValidInventory(request.resource.data) &&
        inventoryImmutableFieldsUnchanged() &&
        (isAdmin() || resource.data.createdBy == request.auth.uid);

      allow delete: if isActive() &&
        (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
